{
  "name": "@signoff/report",
  "version": "0.2.0",
  "description": "SignOff approval-coverage report (Markdown/CSV) over a vault",
  "type": "module",
  "main": "dist/cli.js",
  "bin": { "signoff-report": "dist/cli.js" },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": { "@signoff/vault-core": "^0.2.0" },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": { "node": ">=20.0.0" }
}
