{
  "mcpServers": {
    "chuckle": {
      "command": "chuckle-mcp",
      "args": ["--vault", "/absolute/path/to/your-project-vault"]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit",
        "hooks": [{ "type": "command", "command": "chuckle-gate" }]
      }
    ]
  }
}
